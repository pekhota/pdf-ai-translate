{
  "manifest_version": 3,
  "name": "PDF AI Translate",
  "version": "1.0.0",
  "description": "Select any word in a PDF and translate it using AI with page context.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PDF AI Translate"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdfjs/*", "pdfjs/web/*", "pdfjs/build/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
